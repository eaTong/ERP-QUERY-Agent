    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "mssql": "^12.2.1",
    "mysql2": "^3.20.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
